<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.gluonhq.charm.glisten.control.AppBar?>
<VBox xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jchat.ChatController" spacing="0" fillWidth="true">
    <children>
        <AppBar fx:id="appBar" />
        <ListView fx:id="messagesListView" VBox.vgrow="ALWAYS" />
        <HBox spacing="5" padding="10">
            <TextField fx:id="messageField" HBox.hgrow="ALWAYS" promptText="Type a message..." />
            <Button text="Send" onAction="#onSend" />
        </HBox>
    </children>
</VBox>
