<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import com.gluonhq.charm.glisten.control.AppBar?>

<VBox xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jchat.LoginController" 
      alignment="CENTER" spacing="20" fillWidth="true" style="-fx-background-color: #f4f6fb; -fx-padding: 40;">
    <children>
        <AppBar fx:id="appBar" />
        
        <VBox alignment="CENTER" spacing="10">
            <Text text="Welcome to JChat" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #1976d2;" />
            <Text text="Please login to continue" style="-fx-font-size: 16px; -fx-fill: #666666;" />
        </VBox>

        <VBox spacing="15" maxWidth="400">
            <VBox spacing="5">
                <Label text="Username" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                <TextField fx:id="usernameField" promptText="Enter your username" 
                           style="-fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 16px; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 10;" />
            </VBox>

            <VBox spacing="5">
                <Label text="Password" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                <PasswordField fx:id="passwordField" promptText="Enter your password" 
                               style="-fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 16px; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 10;" />
            </VBox>
        </VBox>

        <Button text="Login" onAction="#onLogin" maxWidth="400"
                style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12; -fx-font-weight: bold; -fx-font-size: 18px; -fx-cursor: hand;" />
        
        <HBox alignment="CENTER" spacing="5">
            <Text text="Don't have an account?" style="-fx-font-size: 14px;" />
            <Hyperlink text="Register" onAction="#onRegister" style="-fx-font-size: 14px; -fx-text-fill: #1976d2; -fx-font-weight: bold;" />
        </HBox>
        
        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #d32f2f; -fx-font-size: 14px;" />
    </children>
</VBox>
