<?xml version="1.0" encoding="UTF-8"?>

<?import com.gluonhq.charm.glisten.mvc.View?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import com.gluonhq.charm.glisten.visual.MaterialDesignIcon?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<View fx:id="dashboardView" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jchat.DashboardController" styleClass="dashboard-container" stylesheets="@style.css">
    <center>
        <VBox spacing="0">
            <children>
                <!-- Search Bar -->
                <VBox styleClass="search-container">
                    <padding>
                        <Insets top="15" bottom="15" left="15" right="15" />
                    </padding>
                    <TextField promptText="Search messages..." styleClass="search-field" />
                </VBox>
                
                <!-- Contact List -->
                <ListView fx:id="contactListView" VBox.vgrow="ALWAYS" styleClass="contact-list" />
            </children>
        </VBox>
    </center>
</View>
