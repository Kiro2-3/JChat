<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import com.gluonhq.charm.glisten.control.AppBar?>

<VBox xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.reloved.controller.LoginController" 
      alignment="CENTER" spacing="0" fillWidth="true" styleClass="login-container" stylesheets="@style.css">
    <children>
        <AppBar fx:id="appBar" />
        
        <StackPane VBox.vgrow="ALWAYS">
            <VBox alignment="CENTER" spacing="30" maxWidth="420" styleClass="login-card" maxHeight="-Infinity">
                <children>
                    <VBox alignment="CENTER" spacing="15">
                        <StackPane styleClass="logo-icon">
                            <Text text="J" styleClass="logo-text" />
                        </StackPane>
                        <VBox alignment="CENTER" spacing="5">
                            <Text text="Welcome Back" styleClass="header-text" />
                            <Text text="Sign in to your JChat account" styleClass="sub-header-text" />
                        </VBox>
                    </VBox>

                    <VBox spacing="20">
                        <VBox spacing="8">
                            <Label text="Username" styleClass="label-text" />
                            <TextField fx:id="usernameField" promptText="Enter your username" styleClass="text-input" />
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Password" styleClass="label-text" />
                            <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="text-input" />
                        </VBox>

                        <HBox alignment="CENTER_LEFT">
                            <CheckBox fx:id="rememberMeCheckbox" text="Remember me" style="-fx-font-size: 13px; -fx-text-fill: #4b5563;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Hyperlink text="Forgot Password?" styleClass="hyperlink" style="-fx-font-size: 13px; -fx-padding: 0;" />
                        </HBox>
                    </VBox>

                    <VBox spacing="20" alignment="CENTER">
                        <Button text="Sign In" onAction="#onLogin" maxWidth="Infinity" styleClass="login-button" />
                        
                        <HBox alignment="CENTER" spacing="5">
                            <Text text="Don't have an account?" style="-fx-font-size: 14px; -fx-fill: #4b5563;" />
                            <Hyperlink text="Create one" onAction="#onRegister" styleClass="hyperlink" style="-fx-font-size: 14px; -fx-padding: 0;" />
                        </HBox>
                        
                        <Label fx:id="errorLabel" text="" styleClass="error-label" />
                    </VBox>
                </children>
            </VBox>
        </StackPane>
    </children>
</VBox>
