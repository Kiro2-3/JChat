

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import com.gluonhq.charm.glisten.control.AppBar?>
<VBox fx:id="mainView" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jchat.ChatController" spacing="0" fillWidth="true" style="-fx-background-color: #f4f6fb; -fx-padding: 0;">
    <children>
        <AppBar fx:id="appBar" />
        <HBox fx:id="connectivityBar" styleClass="connectivity-bar" managed="false" visible="false">
            <Label text="Waiting for network..." styleClass="connectivity-text" />
        </HBox>
        <ListView fx:id="messagesListView" VBox.vgrow="ALWAYS" 
 style="-fx-background-radius: 18; -fx-background-color: #ffffff; -fx-padding: 16 8 16 8; -fx-border-color: #e0e0e0; -fx-border-radius: 18; -fx-font-size: 18px; -fx-effect: dropshadow(gaussian, #e0e0e0, 8, 0.2, 0, 2);" />
        <HBox spacing="12" padding="18" style="-fx-background-color: #ffffff; -fx-background-radius: 0 0 18 18; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0; -fx-effect: dropshadow(gaussian, #e0e0e0, 8, 0.2, 0, -2);">
            <TextField fx:id="messageField" HBox.hgrow="ALWAYS" promptText="Type a message..." style="-fx-background-radius: 24; -fx-background-color: #f0f2f5; -fx-border-color: #cccccc; -fx-border-radius: 24; -fx-padding: 14 20; -fx-font-size: 18px;" />
            <Button text="Send" onAction="#onSend" style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-background-radius: 24; -fx-padding: 14 28; -fx-font-weight: bold; -fx-font-size: 18px; -fx-min-width: 64px; -fx-min-height: 48px;" />
        </HBox>
    </children>
</VBox>
